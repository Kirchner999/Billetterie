<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.billetterie.controller.RegisterController"
           alignment="CENTER">

    <VBox styleClass="glass"
          alignment="CENTER"
          spacing="20"
          maxWidth="350">

        <Label text="Créer un compte" styleClass="title"/>

        <!-- PSEUDO AJOUTÉ -->
        <TextField fx:id="pseudoField"
                   promptText="Pseudo"/>

        <TextField fx:id="nomField"
                   promptText="Nom complet"/>

        <TextField fx:id="emailField"
                   promptText="Email"/>

        <PasswordField fx:id="passwordField"
                       promptText="Mot de passe"/>

        <Button text="S'inscrire" onAction="#handleRegister"/>

        <Hyperlink text="Déjà un compte ? Se connecter"
                   onAction="#goToLogin"/>

        <Button text="Changer thème"
                styleClass="button-secondary"
                onAction="#switchTheme"/>

    </VBox>

</StackPane>
