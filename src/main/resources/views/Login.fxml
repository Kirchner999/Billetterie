<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="fr.billetterie.controller.LoginController"
           alignment="CENTER">

    <HBox alignment="CENTER" spacing="28" maxWidth="920">
        <VBox spacing="14" maxWidth="380">
            <Label text="Dispelltacle" styleClass="section-title"/>
            <Label text="Connecte-toi pour acheter des places, choisir tes sieges et retrouver ton historique d'achats." styleClass="section-subtitle" wrapText="true"/>

            <VBox spacing="10" styleClass="card stat-card">
                <Label text="Fonctionnalites" styleClass="stat-title"/>
                <Label text="Evenements a venir uniquement" styleClass="event-meta"/>
                <Label text="Choix visuel des sieges" styleClass="event-meta"/>
                <Label text="Historique d'achats en tableau" styleClass="event-meta"/>
            </VBox>
        </VBox>

        <VBox styleClass="glass"
              alignment="CENTER_LEFT"
              spacing="16"
              maxWidth="360">

            <Label text="Connexion" styleClass="title"/>
            <Label text="Entre ton nom d'utilisateur et ton mot de passe." styleClass="section-subtitle" wrapText="true"/>

            <TextField fx:id="emailField"
                       promptText="Nom d'utilisateur"/>

            <PasswordField fx:id="passwordField"
                           promptText="Mot de passe"/>

            <Label fx:id="errorLabel" textFill="#e53935" wrapText="true"/>

            <Button text="Se connecter" onAction="#handleLogin" maxWidth="1.7976931348623157E308"/>

            <Hyperlink text="Creer un compte"
                       onAction="#goToRegister"/>

            <Button text="Changer theme"
                    styleClass="button-secondary"
                    onAction="#switchTheme"/>

            <padding>
                <Insets top="28" right="28" bottom="28" left="28"/>
            </padding>
        </VBox>
    </HBox>

</StackPane>
